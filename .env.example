# ═══════════════════════════════════════════════════════════════
# Vision-I — Environment Configuration Template
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in real values
# 3. NEVER commit .env to git — it is in .gitignore
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════

# ── Shared secrets ────────────────────────────────────────────
# Shared API key: .NET API → Python API (X-Internal-Key header)
INTERNAL_API_KEY=change-me-generate-with-python-secrets

# JWT signing key for .NET API access tokens (min 32 chars)
JWT_KEY=change-me-generate-with-python-secrets

# ── Database passwords ────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
NEO4J_PASSWORD=change-me-strong-password
VISIONI_LLM_ENCRYPTION_KEY=change-me-32-char-minimum-secret

# ── Seed admin account ────────────────────────────────────────
# Created on first startup if not already in the database.
# Required for test_api.py and the default admin login.
SEED_ADMIN_EMAIL=admin@vision-i.org
SEED_ADMIN_PASSWORD=Admin1234!

# ── Data source API keys ──────────────────────────────────────
# NewsAPI.org — https://newsapi.org (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# OpenSky Network credentials (optional — anonymous is rate-limited)
# OPENSKY_USER=your_username
# OPENSKY_PASS=your_password

# AIS vessel tracking provider (optional)
# AIS_API_URL=https://your-ais-provider.example/api/v1/vessels
# AIS_API_KEY=your_ais_api_key
# AIS_PROVIDER=generic

# ── Telegram data source (optional) ──────────────────────────
# Get API ID/Hash from https://my.telegram.org/apps (MTProto — full channel access)
# TELEGRAM_API_ID=your_api_id
# TELEGRAM_API_HASH=your_api_hash
# Bot token from @BotFather (simpler, only channels the bot is in)
# TELEGRAM_BOT_TOKEN=your_bot_token
# Comma-separated list of channel usernames to monitor (no @)
# TELEGRAM_CHANNELS=bbcnews,reuters,aljazeera

# ── Python API tuning ─────────────────────────────────────────
GDELT_DELAY=1.5
PIPELINE_WORKERS=4
NLP_BATCH_SIZE=32
ENTITY_RESOLUTION_THRESHOLD=88
LIVE_INTERVAL_SECONDS=300
TEXT_INTERVAL_SECONDS=300

# ── Intelligence scheduler intervals (seconds) ────────────────
# Narrative detection: default every 30 minutes
NARRATIVE_INTERVAL_SECONDS=1800
# Anomaly scan: default every 60 minutes
ANOMALY_INTERVAL_SECONDS=3600
# Influence score recalculation: default every 6 hours
INFLUENCE_INTERVAL_SECONDS=21600

# ── Intelligence algorithm tuning ────────────────────────────
# Hours of events to analyse per narrative detection run
NARRATIVE_WINDOW_HOURS=6
# Z-score threshold for anomaly alerts (lower = more sensitive)
ANOMALY_Z_THRESHOLD=2.0
# Minimum hours between repeated alerts for the same entity
ALERT_COOLDOWN_HOURS=4

# ── LLM / AI inference ───────────────────────────────────────
# Vision-I uses OpenRouter as the primary LLM provider for JARVIS analysis,
# agent mission briefs, and narrative summaries.
# Get a key at https://openrouter.ai — free tier available.
# Default model: meta-llama/llama-3.3-70b-instruct (fast, free tier eligible)
# Override model:  LLM_MODEL=anthropic/claude-3-haiku
OPENROUTER_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Alternative providers (only one needs to be set):
# ANTHROPIC_API_KEY=your_anthropic_key
# OPENAI_API_KEY=your_openai_key
# GEMINI_API_KEY=your_gemini_key
# GROQ_API_KEY=your_groq_key
# OLLAMA_BASE_URL=http://localhost:11434   # local Ollama instance

# ── Alert notifications ───────────────────────────────────────
# POST to this URL when a high/critical anomaly alert fires (optional).
# Payload: { "source": "vision-i", "alerts": [...] }
# Works with Slack incoming webhooks, Discord webhooks, PagerDuty, custom endpoints.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Environment & logging ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# ── NLP model selection ───────────────────────────────────────
# Multilingual NER (handles 10+ language families)
NER_MODEL=Davlan/xlm-roberta-base-ner-hrl

# spaCy model (English fallback)
SPACY_MODEL=en_core_web_sm

# Primary multilingual sentiment
SENTIMENT_MODEL=cardiffnlp/twitter-multilingual-roberta-base-sentiment-multilingual

# English-only sentiment fallback
SENTIMENT_MODEL_FALLBACK=cardiffnlp/twitter-roberta-base-sentiment-latest

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5001
