@page "/workspaces"
@layout AnalystLayout
@inject WorkspaceService Workspace
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Workspaces | Vision-I</PageTitle>

<div class="vi-page">
    <div class="vi-page-hdr">
        <div>
            <div class="vi-kicker">Mission / Workspaces</div>
            <h1 class="vi-h1">Workspaces</h1>
            <div class="vi-sub">THEATRE · OPERATIONS · TRACKING</div>
        </div>
        <div class="vi-page-actions">
            <button class="vi-btn primary sm" @onclick='() => Nav.NavigateTo("/workspaces/new")'>+ New Workspace</button>
            <button class="vi-btn" disabled="@_loading" @onclick="LoadAsync">
                <span class="material-symbols-outlined" style="font-size:15px;">refresh</span>
                Refresh
            </button>
        </div>
    </div>

    @if (_workspaces is { Count: > 0 })
    {
        var activeCount = _workspaces.Count(w => string.Equals(w.Status, "active", StringComparison.OrdinalIgnoreCase));
        var classifiedCount = _workspaces.Count(w => !string.IsNullOrWhiteSpace(w.Classification));
        var recentCount = _workspaces.Count(w => DateTime.UtcNow - w.UpdatedAt.ToUniversalTime() < TimeSpan.FromHours(24));
        <div class="vi-metrics" style="margin-bottom:16px;">
            <div class="vi-metric">
                <div class="vi-metric-label">Workspaces</div>
                <div class="vi-metric-val accent">@_workspaces.Count</div>
                <div class="vi-metric-note">mission theatres</div>
            </div>
            <div class="vi-metric">
                <div class="vi-metric-label">Active</div>
                <div class="vi-metric-val ok">@activeCount</div>
                <div class="vi-metric-note">currently monitored</div>
            </div>
            <div class="vi-metric">
                <div class="vi-metric-label">Updated 24h</div>
                <div class="vi-metric-val @(recentCount > 0 ? "warn" : "")">@recentCount</div>
                <div class="vi-metric-note">fresh snapshots</div>
            </div>
            <div class="vi-metric">
                <div class="vi-metric-label">Classified</div>
                <div class="vi-metric-val">@classifiedCount</div>
                <div class="vi-metric-note">tagged scopes</div>
            </div>
        </div>
    }

    @if (_loading && _workspaces is null)
    {
        <div class="vi-loading">LOADING WORKSPACES</div>
    }
    else if (_error is not null)
    {
        <div class="vi-empty">@_error</div>
    }
    else if (_workspaces?.Count == 0)
    {
        <!-- First-run onboarding wizard -->
        <div style="max-width:640px;margin:40px auto;padding:36px;background:var(--s2);border:1px solid var(--b1);border-radius:var(--r2);text-align:center;">
            <div style="font-size:40px;margin-bottom:12px;">
                <span class="material-symbols-outlined" style="font-size:40px;color:var(--acc);">workspaces</span>
            </div>
            <h2 style="font:700 18px/1.3 var(--font);color:var(--t);margin-bottom:8px;">Welcome to Vision-I Workspaces</h2>
            <p style="font-size:13px;color:var(--tm);line-height:1.65;max-width:480px;margin:0 auto 24px;">
                Workspaces let you group events, entities, and queries into focused intelligence theatres.
                Create your first workspace to get started.
            </p>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px;text-align:left;">
                @foreach (var (icon, title, desc) in new[] {
                    ("layers", "Theatre Focus", "Scope events and actors to a geographic or topical area"),
                    ("search", "Saved Queries", "Persist the queries that matter to your mission"),
                    ("radar", "Operational View", "Correlate assets, entities, and signals in one place"),
                })
                {
                    <div style="background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);padding:14px;">
                        <span class="material-symbols-outlined" style="font-size:20px;color:var(--acc);display:block;margin-bottom:6px;">@icon</span>
                        <div style="font:600 12px/1 var(--font);color:var(--t);margin-bottom:4px;">@title</div>
                        <div style="font-size:11px;color:var(--tf);line-height:1.5;">@desc</div>
                    </div>
                }
            </div>
            <button class="vi-btn primary" @onclick='() => Nav.NavigateTo("/workspaces/new")'>
                Create First Workspace →
            </button>
        </div>
    }
    else
    {
        var visible = FilteredWorkspaces();

        <!-- Search + filter bar -->
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:16px;padding:10px 12px;background:var(--s2);border-radius:var(--r1);">
            <span class="material-symbols-outlined" style="font-size:16px;color:var(--tf);">search</span>
            <input class="vi-input sm" placeholder="Search workspaces…"
                   style="flex:1;min-width:180px;max-width:320px;"
                   @bind="_search" @bind:event="oninput" />
            <select class="vi-select sm" @bind="_statusFilter" style="min-width:110px;">
                <option value="">All status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
            <select class="vi-select sm" @bind="_sortBy" style="min-width:130px;">
                <option value="recent">Sort: Recent</option>
                <option value="az">Sort: A–Z</option>
                <option value="status">Sort: Status</option>
            </select>
            <span style="font-size:11px;color:var(--tf);margin-left:auto;">@visible.Count workspace@(visible.Count == 1 ? "" : "s")</span>
        </div>

        @if (visible.Count == 0)
        {
            <div class="vi-empty">
                <span class="material-symbols-outlined">search_off</span>
                No workspaces match the current filters.
            </div>
        }
        else
        {
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:12px;">
                @foreach (var ws in visible)
                {
                    var age = DateTime.UtcNow - ws.UpdatedAt.ToUniversalTime();
                    var ageLabel = age.TotalMinutes < 60 ? $"{Math.Max(1, (int)age.TotalMinutes)}m ago"
                        : age.TotalHours < 24 ? $"{(int)age.TotalHours}h ago"
                        : $"{(int)age.TotalDays}d ago";
                    <div class="vi-panel" style="padding:0;cursor:pointer;transition:border .15s;overflow:hidden;"
                         @onclick="() => OpenWorkspace(ws.Slug)">
                        <div style="height:3px;background:@(ws.Status == "active" ? "var(--ok)" : "var(--warn)");opacity:.85;"></div>
                        <div style="padding:14px 16px 10px;">
                            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;">
                                <div style="font:600 13px/1.2 var(--font);color:var(--t);max-width:220px;">@ws.Title</div>
                                <div class="vi-chip @(ws.Status == "active" ? "ok" : "warn")" style="flex-shrink:0;">@ws.Status.ToUpper()</div>
                            </div>
                            @if (!string.IsNullOrEmpty(ws.Description))
                            {
                                <div style="font-size:11px;color:var(--tm);line-height:1.45;margin-bottom:8px;">
                                    @(ws.Description.Length > 90 ? ws.Description[..90] + "…" : ws.Description)
                                </div>
                            }
                            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
                                @if (!string.IsNullOrEmpty(ws.Classification))
                                {
                                    <span class="vi-chip info">@ws.Classification</span>
                                }
                                <span class="vi-chip" style="font-size:10px;">@ws.DefaultWindowHours h window</span>
                            </div>
                            <div style="font-size:11px;color:var(--tf);">
                                Updated @ageLabel Â· @ws.UpdatedAt.ToString("dd MMM HH:mm")
                            </div>
                        </div>
                        <div style="border-top:1px solid var(--bd);padding:8px 12px;display:flex;justify-content:flex-end;gap:6px;background:var(--s1);border-radius:0 0 var(--r2) var(--r2);">
                            <button class="vi-btn sm" @onclick:stopPropagation disabled="@(_refreshingSlug == ws.Slug)"
                                    @onclick="() => RefreshCardAsync(ws.Slug)">
                                <span class="material-symbols-outlined" style="font-size:13px;">refresh</span>
                            </button>
                            <button class="vi-btn primary sm" @onclick:stopPropagation
                                    @onclick="() => OpenWorkspace(ws.Slug)">Open Workspace</button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    bool    _loading;
    string? _error;
    string  _search         = "";
    string  _statusFilter   = "";
    string  _sortBy         = "recent";
    string? _refreshingSlug;

    List<WorkspaceListItem>? _workspaces;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loading = _workspaces is null;
        _error = null;
        StateHasChanged();
        try
        {
            var resp = await Workspace.GetWorkspacesAsync();
            _workspaces = resp?.Items ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load workspaces: {ex.Message}";
            Toast.ShowError(_error);
        }
        finally { _loading = false; }
    }

    List<WorkspaceListItem> FilteredWorkspaces()
    {
        var items = (_workspaces ?? []).AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_search))
        {
            var q = _search.Trim();
            items = items.Where(w =>
                w.Title.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                (w.Description?.Contains(q, StringComparison.OrdinalIgnoreCase) == true));
        }
        if (!string.IsNullOrEmpty(_statusFilter))
            items = items.Where(w => w.Status == _statusFilter);
        items = _sortBy switch
        {
            "az"     => items.OrderBy(w => w.Title),
            "status" => items.OrderBy(w => w.Status).ThenByDescending(w => w.UpdatedAt),
            _        => items.OrderByDescending(w => w.UpdatedAt),
        };
        return items.ToList();
    }

    void OpenWorkspace(string slug) => Nav.NavigateTo($"/workspaces/{slug}");

    async Task RefreshCardAsync(string slug)
    {
        _refreshingSlug = slug;
        try
        {
            await Workspace.RefreshWorkspaceAsync(slug);
            Toast.ShowSuccess("Workspace refresh triggered");
        }
        catch { Toast.ShowError("Refresh failed"); }
        finally { _refreshingSlug = null; }
    }
}
