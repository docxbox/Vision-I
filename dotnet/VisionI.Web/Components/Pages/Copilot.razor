@page "/copilot"
@inject CopilotService Svc
@implements IDisposable

<PageTitle>JARVIS | Vision-I</PageTitle>

<div class="vi-page">
    <div class="vi-page-hdr">
        <div>
            <div class="vi-kicker">Vision-I / Native Assistant</div>
            <h1 class="vi-h1">JARVIS</h1>
            <div class="vi-sub">PAGE CONTEXT - LIVE COUNTS - TACTICAL BRIEFINGS</div>
        </div>
        <div class="vi-page-actions">
            <button class="vi-btn" @onclick="Svc.ClearHistory">Clear History</button>
            <button class="vi-btn primary" disabled="@Svc.Busy" @onclick="Svc.TacticalSummaryAsync">Tactical Summary</button>
        </div>
    </div>

    <div class="vi-copilot-briefing">
        <div>
            <div class="vi-label">Attached Surface</div>
            <strong>@Svc.SurfaceLabel</strong>
            <span>@Svc.SurfaceScope</span>
        </div>
        <div>
            <div class="vi-label">Live Picture</div>
            <strong>@Svc.LiveCountSummary</strong>
            <span>Included in every JARVIS prompt.</span>
        </div>
        <div class="vi-copilot-briefing-actions">
            <button class="vi-btn sm" disabled="@Svc.Busy" @onclick="Svc.BriefCurrentSurfaceAsync">Brief current page</button>
            <button class="vi-btn sm" disabled="@Svc.Busy" @onclick="Svc.InvestigateCurrentSurfaceAsync">Investigation plan</button>
            <button class="vi-btn sm" disabled="@Svc.Busy" @onclick="Svc.ReportCurrentSurfaceAsync">Report outline</button>
        </div>
    </div>

    <div class="vi-split wide" style="flex:1;min-height:0;">
        <div class="vi-panel" style="display:flex;flex-direction:column;min-height:0;">
            <div class="vi-panel-hdr"><span class="vi-panel-title">Native Conversation</span></div>

            <div style="flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:10px;">
                @if (!Svc.History.Any())
                {
                    <div class="vi-empty" style="margin:auto;">
                        <span class="material-symbols-outlined">psychology</span>
                        Ask JARVIS anything about the active Vision-I surface.
                    </div>
                }
                else
                {
                    @foreach (var msg in Svc.History)
                    {
                        <div style="display:flex;flex-direction:column;gap:2px;align-items:@(msg.Role == "user" ? "flex-end" : "flex-start");">
                            <div style="font:600 10px/1 var(--mono);color:var(--tf);text-transform:uppercase;padding:0 4px;">
                                @(msg.Role == "user" ? "You" : "JARVIS") - @(msg.Ts.ToString("HH:mm"))
                            </div>
                            <div style="max-width:85%;padding:10px 14px;border-radius:var(--r2);font-size:13px;line-height:1.6;white-space:pre-wrap;word-break:break-word;
                                        background:@(msg.Role == "user" ? "var(--p-bg)" : "var(--s3)");
                                        border:1px solid @(msg.Role == "user" ? "var(--p-bd)" : "var(--bd)");
                                        color:@(msg.IsError ? "var(--err)" : "var(--t2)");">
                                @msg.Content
                            </div>
                            @if (msg.Actions is { Count: > 0 })
                            {
                                <div style="display:flex;gap:6px;flex-wrap:wrap;max-width:85%;margin-top:2px;">
                                    @foreach (var act in msg.Actions)
                                    {
                                        <button class="vi-chip @(act.IsMutation ? "warn" : "info")" style="cursor:pointer;"
                                                disabled="@Svc.Busy" @onclick="() => Svc.ExecuteActionAsync(act)">@act.Label</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
                @if (Svc.Busy)
                {
                    <div class="vi-loading" style="align-self:flex-start;padding:8px 0;">JARVIS THINKING</div>
                }
            </div>

            <div style="padding:12px;border-top:1px solid var(--bd);display:flex;gap:8px;">
                <input class="vi-input" style="flex:1;" placeholder="Ask JARVIS..."
                       @bind="Svc.Input" @bind:event="oninput"
                       @onkeyup="OnKeyUp" disabled="@Svc.Busy" />
                <button class="vi-btn primary" disabled="@(Svc.Busy || string.IsNullOrWhiteSpace(Svc.Input))"
                        @onclick="() => Svc.AskAsync()">Send</button>
            </div>
        </div>

        <div class="vi-stack" style="min-height:0;overflow-y:auto;">
            <div class="vi-panel soft">
                <div class="vi-panel-hdr"><span class="vi-panel-title">Platform Actions</span></div>
                <div class="vi-panel-body vi-stack">
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.BriefCurrentSurfaceAsync">Brief Current Page</button>
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.InvestigateCurrentSurfaceAsync">Investigation Plan</button>
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.ReportCurrentSurfaceAsync">Report Outline</button>
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.ThreatReportAsync">Threat Report</button>
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.SentimentReportAsync">Sentiment Report</button>
                    <button class="vi-btn" style="width:100%;text-align:left;" disabled="@Svc.Busy"
                            @onclick="Svc.InfluenceReportAsync">Influence Report</button>
                </div>
            </div>

            <div class="vi-panel soft">
                <div class="vi-panel-hdr"><span class="vi-panel-title">Explain Event</span></div>
                <div class="vi-panel-body vi-stack">
                    <div class="vi-form-row">
                        <input class="vi-input sm" style="flex:1;" placeholder="Event ID..." @bind="Svc.EventIdInput" />
                        <button class="vi-btn sm" disabled="@Svc.Busy"
                                @onclick="() => Svc.ExplainEventAsync(Svc.EventIdInput)">Explain</button>
                    </div>
                    <div class="vi-form-row">
                        <button class="vi-btn sm" style="flex:1;" disabled="@Svc.Busy"
                                @onclick="() => Svc.SimilarEventsAsync(Svc.EventIdInput)">Similar</button>
                        <button class="vi-btn sm" style="flex:1;" disabled="@Svc.Busy"
                                @onclick="() => Svc.RecommendEventAsync(Svc.EventIdInput)">Recommend</button>
                    </div>
                </div>
            </div>

            @if (Svc.LastEvidence is { } ev)
            {
                <div class="vi-panel soft">
                    <div class="vi-panel-hdr"><span class="vi-panel-title">Intelligence Evidence</span></div>
                    <div class="vi-panel-body vi-stack">
                        @if (!string.IsNullOrWhiteSpace(Svc.WhatChangedSummary))
                        {
                            <div>
                                <div class="vi-label">What Changed</div>
                                <div style="font-size:12px;color:var(--t2);line-height:1.5;">@Svc.WhatChangedSummary</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Svc.WhyItMattersSummary))
                        {
                            <div>
                                <div class="vi-label">Why It Matters</div>
                                <div style="font-size:12px;color:var(--t2);line-height:1.5;">@Svc.WhyItMattersSummary</div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Svc.RecommendedActionSummary))
                        {
                            <div>
                                <div class="vi-label">Recommended Action</div>
                                <div style="font-size:12px;color:var(--p2);line-height:1.5;">@Svc.RecommendedActionSummary</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Svc.OnChanged += OnSvcChanged;
    }

    void OnSvcChanged() => InvokeAsync(StateHasChanged);

    async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !Svc.Busy && !string.IsNullOrWhiteSpace(Svc.Input))
            await Svc.AskAsync();
    }

    public void Dispose() => Svc.OnChanged -= OnSvcChanged;
}
