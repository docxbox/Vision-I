            </div>

            <!-- RIGHT: Triage + Assessment -->
            <div class="vi-stack" style="flex:1;min-width:260px;max-width:340px;">
                <div class="vi-panel">
                    <div class="vi-panel-hdr">
                        <span class="vi-panel-title">Triage</span>
                        @if (Svc.Triage is { } tr)
                        {
                            <span class="vi-chip @SevCls(tr.Priority)">@tr.Priority.ToUpperInvariant()</span>
                        }
                    </div>
                    <div class="vi-panel-body vi-stack">
                        <div class="vi-field">
                            <label class="vi-label">Status</label>
                            <select class="vi-select sm" @bind="Svc.TriageStatus">
                                <option value="new">New</option>
                                <option value="reviewing">Reviewing</option>
                                <option value="escalated">Escalated</option>
                                <option value="actioned">Actioned</option>
                                <option value="dismissed">Dismissed</option>
                            </select>
                        </div>
                        <div class="vi-field">
                            <label class="vi-label">Priority</label>
                            <select class="vi-select sm" @bind="Svc.TriagePriority">
                                <option value="critical">Critical</option>
                                <option value="high">High</option>
                                <option value="medium">Medium</option>
                                <option value="low">Low</option>
