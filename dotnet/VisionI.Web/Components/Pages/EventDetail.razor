                    <div class="vi-panel">
                        <div class="vi-panel-hdr"><span class="vi-panel-title">Evidence Summary</span></div>
                        <div class="vi-panel-body">
                            <div class="vi-detail">
                                @if (Svc.RelatedEventCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Related events</span><span class="vi-detail-val">@Svc.RelatedEventCount</span></div>
                                }
                                @if (Svc.RelatedSignalCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Signals</span><span class="vi-detail-val">@Svc.RelatedSignalCount</span></div>
                                }
                                @if (Svc.ClusteredSignalCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Clustered signals</span><span class="vi-detail-val">@Svc.ClusteredSignalCount</span></div>
                                }
                                @if (Svc.LinkedAlertCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Alerts</span><span class="vi-detail-val">@Svc.LinkedAlertCount</span></div>
                                }
                                @if (Svc.SocialCorrelationCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Social posts</span><span class="vi-detail-val">@Svc.SocialCorrelationCount</span></div>
                                }
                                @if (Svc.NarrativeCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Narratives</span><span class="vi-detail-val">@Svc.NarrativeCount</span></div>
                                }
                                @if (Svc.PlaybookCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Playbooks</span><span class="vi-detail-val">@Svc.PlaybookCount</span></div>
                                }
                                @if (Svc.SimilarDecisionCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Similar decisions</span><span class="vi-detail-val">@Svc.SimilarDecisionCount</span></div>
                                }
                                @if (Svc.SourceFamilyCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Source families</span><span class="vi-detail-val">@Svc.SourceFamilyCount</span></div>
                                }
                                @if (Svc.PhysicalAssetCount > 0)
                                {
                                    <div class="vi-detail-row"><span class="vi-detail-key">Physical assets</span><span class="vi-detail-val">@Svc.PhysicalAssetCount</span></div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Workspace picker modal -->
@if (_wsPickerOpen)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:300;display:flex;align-items:center;justify-content:center;"
         @onclick='() => _wsPickerOpen = false'>
        <div style="background:var(--s1);border:1px solid var(--bd);border-radius:var(--r2);padding:20px;width:460px;max-height:580px;overflow-y:auto;" @onclick:stopPropagation>
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                <div style="font-size:14px;font-weight:600;">Add to Workspace</div>
                <button class="vi-btn sm" @onclick='() => _wsPickerOpen = false'>✕</button>
            </div>
            <div style="font-size:11px;color:var(--tm);margin-bottom:14px;">Select a workspace to investigate this event:</div>
            @if (_wsPickerLoading)
            {
                <div class="vi-loading" style="padding:20px;">LOADING</div>
            }
            else if (!_workspaces.Any())
            {
                <div class="vi-empty" style="padding:20px;">
                    No workspaces.
                    <a href="/workspaces/new" style="color:var(--acc);">Create one →</a>
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:7px;">
                    @foreach (var ws in _workspaces)
                    {
                        <div class="vi-panel" style="padding:12px;cursor:pointer;"
                             @onclick='() => GoToWorkspace(ws)'>
                            <div style="display:flex;justify-content:space-between;align-items:center;">
                                <div>
                                    <div style="font-size:13px;font-weight:600;">@ws.Title</div>
                                    <div style="font-size:10px;color:var(--tf);">@ws.Slug</div>
                                </div>
                                <span class="vi-chip @(ws.Status == "active" ? "ok" : "")">@ws.Status</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string? EventId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "from")] public string? FromWorkspace { get; set; }

    string? _fromWorkspaceTitle;
    bool _bookmarked;
    string? _bookmarkId;

    protected override async Task OnInitializedAsync()
    {
        Svc.OnChanged += OnSvcChanged;
        await Task.WhenAll(
            Svc.LoadAsync(EventId),
            ResolveWorkspaceTitleAsync(),
            CheckBookmarkAsync()
        );
    }

    protected override async Task OnParametersSetAsync()
    {
        var tasks = new List<Task>();
        if (!string.Equals(Svc.LoadedEventId, EventId, StringComparison.OrdinalIgnoreCase))
            tasks.Add(Svc.LoadAsync(EventId));
        if (!string.IsNullOrWhiteSpace(FromWorkspace) && _fromWorkspaceTitle is null)
            tasks.Add(ResolveWorkspaceTitleAsync());
        if (tasks.Any()) await Task.WhenAll(tasks);
    }

    async Task ResolveWorkspaceTitleAsync()
    {
        if (string.IsNullOrWhiteSpace(FromWorkspace)) return;
        try
        {
            var ws = await WorkspaceSvc.GetWorkspaceAsync(FromWorkspace);
            _fromWorkspaceTitle = ws?.Title;
        }
        catch { }
    }

    void OnSvcChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Svc.OnChanged -= OnSvcChanged;

    async Task CheckBookmarkAsync()
    {
        if (string.IsNullOrWhiteSpace(EventId) || Auth?.CurrentUser?.Id is null) return;
        try
        {
            var resp = await Api.GetAsync<System.Text.Json.JsonElement?>(
                $"api/bookmarks?user_id={Uri.EscapeDataString(Auth.CurrentUser.Id)}");
            if (resp?.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                foreach (var item in resp.Value.EnumerateArray())
                {
                    if (item.TryGetProperty("event_id", out var eid) && eid.GetString() == EventId)
                    {
                        _bookmarked = true;
                        _bookmarkId = item.TryGetProperty("bookmark_id", out var bid) ? bid.GetString() : null;
                        break;
                    }
                }
            }
        }
        catch { }
    }

    async Task ToggleBookmarkAsync()
    {
        if (string.IsNullOrWhiteSpace(EventId) || Auth?.CurrentUser?.Id is null) return;
        if (_bookmarked && _bookmarkId is not null)
        {
            await Api.DeleteAsync($"api/bookmarks/{_bookmarkId}?user_id={Uri.EscapeDataString(Auth.CurrentUser.Id)}");
            _bookmarked = false; _bookmarkId = null;
        }
        else
        {
            var result = await Api.PostAsync<System.Text.Json.JsonElement?>(
                $"api/bookmarks?user_id={Uri.EscapeDataString(Auth.CurrentUser.Id)}",
                new { event_id = EventId });
            if (result?.TryGetProperty("bookmark_id", out var bid) == true)
            {
                _bookmarkId = bid.GetString();
                _bookmarked = true;
            }
        }
        StateHasChanged();
    }

    // Workspace picker state
    bool                    _wsPickerOpen;
    bool                    _wsPickerLoading;
    List<WorkspaceListItem> _workspaces = new();

    void OpenWsPicker()
    {
        _wsPickerOpen = true;
        _ = LoadWorkspacesAsync();
    }

    async Task LoadWorkspacesAsync()
    {
        if (_workspaces.Any()) return;
        _wsPickerLoading = true;
        StateHasChanged();
        try
        {
            var resp = await WorkspaceSvc.GetWorkspacesAsync();
            _workspaces = resp?.Items ?? new();
        }
        finally
        {
            _wsPickerLoading = false;
            StateHasChanged();
        }
    }

    void GoToWorkspace(WorkspaceListItem ws)
    {
        _wsPickerOpen = false;
        Nav.NavigateTo($"/workspaces/{Uri.EscapeDataString(ws.Slug)}");
    }

    static string RiskCls(double v) => v switch { > 0.7 => "err", > 0.4 => "warn", _ => "" };
    static string SevCls(string s) => s.ToLowerInvariant() switch { "critical" => "err", "high" => "warn", _ => "" };
    static string SentCls2(double v) => v > 0.6 ? "ok" : v < 0.4 ? "err" : "";
    static string? ExtractDomain2(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            var h = uri.Host;
            return h.StartsWith("www.", StringComparison.OrdinalIgnoreCase) ? h[4..] : h;
        }
        return null;
    }
}
