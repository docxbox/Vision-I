                            <div class="vi-detail-row"><span class="vi-detail-key">Corroboration</span><span class="vi-detail-val">@Svc.CorroborationScore.ToString("0.00")</span></div>
                        </div>
                        <div style="font-size:12px;color:var(--tm);line-height:1.55;border-top:1px solid var(--bd);padding-top:8px;">@Svc.AnalystAssessment</div>
                    </div>
